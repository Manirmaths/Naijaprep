# Backend environment variables

# Set to "production" on the deployed API only. Controls: secure cookie flag,
# HSTS header, and whether interactive API docs (/docs, /redoc, /openapi.json)
# are served at all (disabled in production).
ENV=development

SECRET_KEY=change-this-to-a-long-random-string
DATABASE_URL=sqlite:///./naijaprep.db
# For Postgres in production:
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Comma-separated list of allowed frontend origins (for CORS + cookies)
FRONTEND_ORIGINS=http://localhost:5173

# JWT cookie settings
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Paystack. Leave both blank and /api/payments/initialize returns a clear
# 501 instead of a real checkout -- the rest of the app (including the free
# mock exam allowance below) still works fine unconfigured.
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
# Placeholder pricing/plan -- a real business decision, not a permanent
# default. Amount is in kobo (1/100 naira): 150000 = NGN 1,500.00.
PREMIUM_PRICE_KOBO=150000
PREMIUM_DURATION_DAYS=30
# How many full JAMB mock exams a non-premium user gets before /api/mock/start
# starts returning 402 -- the first concrete premium/free split in the app.
FREE_MOCK_EXAMS=1

# Resend (password reset emails). Leave blank to just log the reset link
# instead of sending a real email.
RESEND_API_KEY=
RESEND_FROM_EMAIL=Naija Prep <noreply@naijaprep.com.ng>
PUBLIC_APP_URL=http://localhost:5173

# OpenAI (AI tutor + admin auto-tagging). Leave blank and both features fall
# back to a friendly "not set up yet" response instead of failing.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
TUTOR_DAILY_LIMIT=30

# Web Push (PWA notifications). Generate a pair with the one-liner in
# app/config.py's comment above VAPID_PRIVATE_KEY. Leave blank and push just
# no-ops (subscribe/unsubscribe still work, sends are skipped).
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIM_EMAIL=mailto:you@example.com
# Shared secret an external cron (e.g. cron-job.org) passes as the
# X-Cron-Secret header to trigger POST /api/notifications/send-reminders.
NOTIFICATIONS_CRON_SECRET=
